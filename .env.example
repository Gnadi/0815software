# Contact form — Resend API key
# Sign up at https://resend.com and create an API key.
# Without this, form submissions are logged to the console only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives contact-form submissions
CONTACT_TO_EMAIL=hello@0815software.com

# "From" address (must be a verified Resend domain)
CONTACT_FROM_EMAIL=contact@0815software.com
