---
import SubPage from '../layouts/SubPage.astro';

export const prerender = true;

const licensePoints = [
  {
    heading: 'Four sentences. No exceptions.',
    body: 'The MIT License grants permission to use, copy, modify, merge, publish, distribute, sublicense, and sell the software. There is no open-core carve-out, no commercial-use restriction, and no "enterprise edition" that triggers different terms.',
  },
  {
    heading: 'No dual licensing.',
    body: 'Some vendors publish source under a permissive license and then sell a "commercial licence" for anything production-adjacent. We do not. MIT is MIT. Your use case does not change the terms.',
  },
  {
    heading: 'Your data stays yours.',
    body: 'Software runs on your infrastructure. We do not process your data, host your database, or have any access to production systems after hand-off. There is no SaaS endpoint sending data home.',
  },
  {
    heading: 'Source code audit, no request needed.',
    body: 'The repository is public. Your security team can audit it today, without signing an NDA, without a vendor review request, and without waiting for a SOC 2 report to arrive by email.',
  },
];

const gdrpItems = [
  ['Data processor role', 'None — we are not a data processor once the software is handed off'],
  ['Data residency', 'You choose: your cloud, your region, your contract'],
  ['Sub-processors', 'Zero — no third-party SaaS dependencies in the module stack'],
  ['DPA requirement', 'Not applicable post-handoff; available on request for the build phase'],
  ['Right to erasure', 'You implement it — you have the schema and the code'],
];
---

<SubPage
  title="For Legal Teams — 0815software"
  description="MIT license, no lock-in, no hidden data processing. What legal and compliance teams need to know about 0815software."
  section="§ F3"
  sectionName="Legal teams"
  eyebrow="DIN 0815/F3 · FOR LEGAL TEAMS"
  heading="One licence.<br />One page."
  lead="MIT. No exceptions, no dual licensing, no hidden commercial terms. What your team needs to review is public and short."
>

  <!-- License points -->
  <section class="legal-points-section">
    <div class="legal-points__inner">
      <div class="section-rail" aria-hidden="true">
        <div class="section-rail__num">§ F3.01</div>
        <div class="section-rail__name">Licensing</div>
      </div>
      <div class="legal-points__list">
        {licensePoints.map((p) => (
          <div class="legal-point">
            <h2 class="legal-point__heading">{p.heading}</h2>
            <p class="legal-point__body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GDPR table -->
  <section class="legal-gdpr-section">
    <div class="legal-gdpr__inner">
      <div class="section-rail" aria-hidden="true">
        <div class="section-rail__num">§ F3.02</div>
        <div class="section-rail__name">GDPR</div>
      </div>
      <div class="legal-gdpr__content">
        <h2 class="legal-gdpr__h2">GDPR considerations.</h2>
        <div class="legal-gdpr__table">
          {gdrpItems.map(([key, val]) => (
            <div class="legal-gdpr__row">
              <span class="legal-gdpr__key">{key}</span>
              <span class="legal-gdpr__val">{val}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Read the license -->
  <section class="legal-cta-section">
    <div class="legal-cta__inner">
      <div class="section-rail" aria-hidden="true">
        <div class="section-rail__num">§ F3.03</div>
        <div class="section-rail__name">Read it</div>
      </div>
      <div>
        <p class="legal-cta__body">
          The full MIT license text is on this site. If your review process requires a signed copy on company letterhead, write to <a href="mailto:hello@0815software.com" class="legal-link">hello@0815software.com</a>. Questions about the build-phase DPA are answered the same way.
        </p>
        <a href="/mit-license" class="btn btn--ghost">Read the MIT License →</a>
      </div>
    </div>
  </section>

</SubPage>

<style>
.legal-points-section {
  padding: var(--sec-y-sm) var(--pad-x);
  border-bottom: 1px solid var(--line);
}
.legal-points__inner {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 48px;
  align-items: start;
}
.legal-points__list {
  display: flex;
  flex-direction: column;
  gap: 40px;
}
.legal-point {
  padding-bottom: 40px;
  border-bottom: 1px solid var(--line);
  max-width: 680px;
}
.legal-point:last-child { border-bottom: none; padding-bottom: 0; }
.legal-point__heading {
  font-family: 'Inter Tight', sans-serif;
  font-size: 22px;
  font-weight: 500;
  letter-spacing: -0.3px;
  margin-bottom: 12px;
}
.legal-point__body {
  font-size: 15px;
  line-height: 1.65;
  color: var(--fg-dim);
}

.legal-gdpr-section {
  padding: var(--sec-y-sm) var(--pad-x);
  border-bottom: 1px solid var(--line);
  background: var(--bg-2);
}
.legal-gdpr__inner {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 48px;
  align-items: start;
}
.legal-gdpr__h2 {
  font-family: 'Inter Tight', sans-serif;
  font-size: 28px;
  font-weight: 500;
  letter-spacing: -0.5px;
  margin-bottom: 28px;
}
.legal-gdpr__table {
  display: flex;
  flex-direction: column;
  max-width: 760px;
}
.legal-gdpr__row {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 32px;
  padding: 14px 0;
  border-bottom: 1px solid var(--line);
  align-items: baseline;
}
.legal-gdpr__key {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--fg-mute);
  letter-spacing: 0.5px;
}
.legal-gdpr__val {
  font-size: 14px;
  color: var(--fg-dim);
  line-height: 1.5;
}

.legal-cta-section {
  padding: var(--sec-y-sm) var(--pad-x);
}
.legal-cta__inner {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 48px;
  align-items: start;
}
.legal-cta__body {
  font-size: 15px;
  line-height: 1.65;
  color: var(--fg-dim);
  max-width: 560px;
  margin-bottom: 32px;
}
.legal-link {
  color: var(--fg);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--line-strong);
}
.legal-link:hover { text-decoration-color: var(--fg); }

@media (max-width: 999px) {
  .legal-points__inner,
  .legal-gdpr__inner,
  .legal-cta__inner { grid-template-columns: 1fr; gap: 24px; }
  .legal-gdpr__row { grid-template-columns: 1fr; gap: 6px; }
}
</style>
