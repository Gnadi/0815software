---
import SubPage from '../layouts/SubPage.astro';

export const prerender = true;

const modules = [
  { n: 'MOD-01', title: 'Customer Portal',       body: 'Self-service access to orders, documents, and status. No account manager required.',          scope: '3–4 WKS' },
  { n: 'MOD-02', title: 'Admin Dashboard',        body: 'Internal CRUD interface over any data model. Tables, filters, bulk actions, exports.',         scope: '2–3 WKS' },
  { n: 'MOD-03', title: 'Inventory Management',   body: 'Stock levels, SKUs, warehouse locations, and purchase order tracking in one place.',           scope: '4–5 WKS' },
  { n: 'MOD-04', title: 'Invoice & Billing',      body: 'Generate, send, and track invoices. PDF export, payment status, customer ledger.',             scope: '3–4 WKS' },
  { n: 'MOD-05', title: 'Employee Directory',     body: 'Org chart, roles, contact data, and department structure. Integrates with HR onboarding.',     scope: '2–3 WKS' },
  { n: 'MOD-06', title: 'Procurement Tracker',    body: 'RFQ, purchase orders, multi-tier approval workflows. Export to any ERP CSV format.',           scope: '4–6 WKS' },
  { n: 'MOD-07', title: 'Storefront',             body: 'Product catalogue, cart, checkout, and order management. No SaaS fees, no revenue cut.',       scope: '5–6 WKS' },
  { n: 'MOD-08', title: 'Reporting Suite',        body: 'Scheduled exports, pivot tables, and chart embeds built on top of your existing database.',    scope: '3–4 WKS' },
  { n: 'MOD-09', title: 'Document Management',    body: 'Upload, tag, version, and control access. Matter-based or project-based access controls.',     scope: '3–4 WKS' },
  { n: 'MOD-10', title: 'CRM Lite',               body: 'Contacts, deals, activity log, and pipeline view. No AI upsells, no seat caps, no surprises.', scope: '3–5 WKS' },
  { n: 'MOD-11', title: 'Time Tracking',          body: 'Project allocation, daily entry, and export to payroll or billing. Works offline.',            scope: '2–3 WKS' },
  { n: 'MOD-12', title: 'Support Ticket System',  body: 'Inbound queue, assignment, status tracking, and SLA timers. Email and web intake.',            scope: '3–4 WKS' },
];
---

<SubPage
  title="Modules — 0815software"
  description="Twelve standard software modules for standard business problems. Scoped, MIT-licensed, and yours to keep."
  section="§ P1"
  sectionName="Modules"
  eyebrow="DIN 0815/M · MODULE CATALOGUE"
  heading="What we build."
  lead="Twelve standard modules, each one a solved problem. Fixed scope, fixed price, handed off in weeks."
>

  <!-- Module grid -->
  <section class="modules-grid-section">
    <div class="modules-grid__head">
      <div class="section-rail" aria-hidden="true">
        <div class="section-rail__num">§ P1.01</div>
        <div class="section-rail__name">Catalogue</div>
      </div>
      <p class="modules-grid__intro">
        Every module ships MIT-licensed with full source code. Pick one, combine several, or commission a custom scope built on top of an existing module.
      </p>
    </div>

    <div class="modules-grid">
      <div class="modules-grid__spacer" aria-hidden="true"></div>
      {modules.map((mod) => (
        <article class="mod-card">
          <div class="mod-card__num">{mod.n}</div>
          <h2 class="mod-card__title">{mod.title}</h2>
          <p class="mod-card__body">{mod.body}</p>
          <div class="mod-card__meta">TYPICAL SCOPE · {mod.scope}</div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="modules-cta-section">
    <div class="modules-cta__inner">
      <div class="section-rail" aria-hidden="true">
        <div class="section-rail__num">§ P1.02</div>
        <div class="section-rail__name">Commission</div>
      </div>
      <div class="modules-cta__content">
        <h2 class="modules-cta__h2">Need something not on this list?</h2>
        <p class="modules-cta__body">
          If it's a standard business problem, we've likely seen it. Describe what you need in a paragraph — we'll tell you if it maps to an existing module, a combination, or a new scope. New modules get published to this catalogue once built.
        </p>
        <a href="/#contact" class="btn btn--primary">Start a project →</a>
      </div>
    </div>
  </section>

</SubPage>

<style>
/* ─── Module grid section ─────────────────────────────────────────── */
.modules-grid-section {
  padding: var(--sec-y-sm) var(--pad-x);
  border-bottom: 1px solid var(--line);
}

.modules-grid__head {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 48px;
  margin-bottom: 64px;
  align-items: start;
}

.modules-grid__intro {
  font-size: 15px;
  line-height: 1.65;
  color: var(--fg-dim);
  max-width: 640px;
}

.modules-grid {
  display: grid;
  grid-template-columns: 120px repeat(3, 1fr);
  gap: 0;
}

.modules-grid__spacer { /* empty rail spacer */ }

/* Module card */
.mod-card {
  padding: 28px 28px 28px 0;
  border-top: 1px solid var(--line);
  border-right: 1px solid var(--line);
}
.mod-card:nth-child(4n) { border-right: none; }

.mod-card__num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 0.8px;
  margin-bottom: 16px;
}

.mod-card__title {
  font-family: 'Inter Tight', sans-serif;
  font-size: 22px;
  font-weight: 500;
  letter-spacing: -0.4px;
  margin-bottom: 12px;
}

.mod-card__body {
  font-size: 14px;
  line-height: 1.6;
  color: var(--fg-dim);
  margin-bottom: 24px;
}

.mod-card__meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--fg-mute);
  letter-spacing: 0.8px;
  padding-top: 14px;
  border-top: 1px solid var(--line);
}

/* ─── CTA section ─────────────────────────────────────────────────── */
.modules-cta-section {
  padding: var(--sec-y-sm) var(--pad-x);
}

.modules-cta__inner {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 48px;
  align-items: start;
}

.modules-cta__h2 {
  font-family: 'Inter Tight', sans-serif;
  font-size: 36px;
  font-weight: 500;
  letter-spacing: -0.8px;
  margin-bottom: 20px;
}

.modules-cta__body {
  font-size: 15px;
  line-height: 1.65;
  color: var(--fg-dim);
  max-width: 560px;
  margin-bottom: 32px;
}

/* ─── Responsive ──────────────────────────────────────────────────── */
@media (max-width: 1199px) {
  .modules-grid { grid-template-columns: 120px repeat(3, 1fr); }
  .modules-grid__head { gap: 32px; }
}

@media (max-width: 999px) {
  .modules-grid__head { grid-template-columns: 1fr; }
  .modules-grid { grid-template-columns: repeat(2, 1fr); }
  .modules-grid__spacer { display: none; }
  .mod-card { padding: 24px; }
  .mod-card:nth-child(4n) { border-right: 1px solid var(--line); }
  .mod-card:nth-child(2n) { border-right: none; }
  .modules-cta__inner { grid-template-columns: 1fr; }
}

@media (max-width: 767px) {
  .modules-grid { grid-template-columns: 1fr; }
  .mod-card { border-right: none !important; padding: 24px 0; }
  .modules-cta__h2 { font-size: 28px; }
}
</style>
