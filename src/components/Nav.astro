---
import Monogram from './Monogram.astro';
---

<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav__brand" aria-label="0815software home">
    <Monogram size={32} />
    <span class="nav__wordmark">0815software</span>
  </a>

  <div class="nav__links">
    <a href="/#products" data-i18n="nav.products">Products</a>
    <a href="/#how-it-works" data-i18n="nav.how">How it works</a>
    <a href="/#catch" data-i18n="nav.catch">The catch</a>
    <a href="/#compare" data-i18n="nav.compare">Compare</a>
    <a href="/#about" data-i18n="nav.about">About</a>
  </div>

  <div class="nav__actions">
    <a
      href="https://github.com/Gnadi/0815software"
      target="_blank"
      rel="noopener noreferrer"
      class="nav__github"
    ><svg class="nav__octocat" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> GitHub ↗</a>
    <a href="/#contact" class="nav__cta" data-i18n="nav.cta">START A PROJECT</a>
  </div>
</nav>

<style>
.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px var(--pad-x);
  border-bottom: 1px solid var(--line);
  position: sticky;
  top: 0;
  background: var(--bg);
  z-index: 50;
}

.nav__brand {
  display: flex;
  align-items: center;
  gap: 14px;
}

.nav__wordmark {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: -0.2px;
  color: var(--fg);
}

.nav__links {
  display: flex;
  gap: 36px;
  font-family: 'Inter Tight', sans-serif;
  font-size: 14px;
  color: var(--fg-dim);
}

.nav__links a {
  transition: color 100ms ease-out;
}
.nav__links a:hover { color: var(--fg); }

.nav__actions {
  display: flex;
  gap: 12px;
  align-items: center;
}

.nav__github {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Inter Tight', sans-serif;
  font-size: 14px;
  color: var(--fg-dim);
  transition: color 100ms ease-out;
}
.nav__github:hover { color: var(--fg); }

.nav__octocat {
  width: 15px;
  height: 15px;
  fill: currentColor;
  flex-shrink: 0;
}

.nav__cta {
  padding: 9px 16px;
  background: var(--accent);
  color: #0A0A0A;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  border-radius: 2px;
  border: 1px solid var(--accent);
  transition: opacity 100ms ease-out;
}
.nav__cta:hover { opacity: 0.88; }

@media (max-width: 1199px) {
  .nav { padding: 20px var(--pad-x); }
}

@media (max-width: 767px) {
  .nav__links { display: none; }
  .nav { padding: 18px var(--pad-x); gap: 12px; }
}
</style>
