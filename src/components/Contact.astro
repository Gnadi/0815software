---
// §07 — Contact
// Grid: 120px | 1fr | 1fr

const contactMeta = [
  ['EMAIL',    'hello@0815software.com'],
  ['OFFICE',   'Berlin, DE · CET'],
  ['GITHUB',   'github.com/0815software'],
  ['RESPONSE', '\u003c 24h, weekdays'],
];
---

<section id="contact" class="contact">
  <div class="contact__grid">

    <!-- Left rail -->
    <div class="section-rail" aria-hidden="true">
      <div class="section-rail__num">§ 07</div>
      <div class="section-rail__name">Contact</div>
    </div>

    <!-- Center: heading + meta -->
    <div class="contact__info">
      <div class="section-label-inline" aria-hidden="true">
        <span class="section-label-inline__num">§ 07</span> · Contact
      </div>

      <h2 class="contact__h2">
        Start a<br />project.
      </h2>

      <p class="contact__p1">
        Describe what you need in a paragraph. We'll reply within one business day with a
        candid yes, no, or here's-what-it-takes — and a fixed-price quote if the scope is standard.
      </p>

      <p class="contact__p2">
        No NDAs to sign. No sales funnel. No calendar invite for a 45-minute discovery call
        before anyone answers a single question. Write to a human, get a human back.
      </p>

      <!-- Contact meta -->
      <dl class="contact__meta-grid">
        {contactMeta.map(([k, v]) => (
          <div class="contact__meta-item">
            <dt class="contact__meta-key">{k}</dt>
            <dd class="contact__meta-val">{v}</dd>
          </div>
        ))}
      </dl>
    </div>

    <!-- Right: contact form -->
    <div class="contact-form-card">
      <form id="contact-form" class="contact-form" novalidate>
        <!-- Row 1: Name + Company -->
        <div class="contact-form__row-2">
          <div class="contact-form__field">
            <label class="contact-form__label" for="cf-name">NAME</label>
            <input
              id="cf-name"
              name="name"
              type="text"
              class="contact-form__input"
              placeholder="Jane Doe"
              autocomplete="name"
              required
            />
            <span class="contact-form__error" id="cf-name-error" aria-live="polite"></span>
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="cf-company">COMPANY</label>
            <input
              id="cf-company"
              name="company"
              type="text"
              class="contact-form__input"
              placeholder="Acme GmbH"
              autocomplete="organization"
            />
          </div>
        </div>

        <!-- Email -->
        <div class="contact-form__field">
          <label class="contact-form__label" for="cf-email">EMAIL</label>
          <input
            id="cf-email"
            name="email"
            type="email"
            class="contact-form__input"
            placeholder="jane@acme.com"
            autocomplete="email"
            required
          />
          <span class="contact-form__error" id="cf-email-error" aria-live="polite"></span>
        </div>

        <!-- Message -->
        <div class="contact-form__field">
          <label class="contact-form__label" for="cf-message">WHAT DO YOU NEED?</label>
          <textarea
            id="cf-message"
            name="message"
            class="contact-form__textarea"
            placeholder="A customer portal for order tracking…"
            rows="4"
            required
          ></textarea>
          <span class="contact-form__error" id="cf-message-error" aria-live="polite"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="contact-form__submit" id="cf-submit">
          Send — reply in 1 business day →
        </button>

        <!-- Form-level status -->
        <p class="contact-form__status" id="cf-status" aria-live="polite"></p>
      </form>
    </div>

  </div>
</section>

<style>
.contact {
  padding: var(--sec-y-sm) var(--pad-x);
  border-bottom: 1px solid var(--line);
}

.contact__grid {
  display: grid;
  grid-template-columns: 120px 1fr 1fr;
  gap: 64px;
  align-items: start;
}

/* ─── Info column ────────────────────────────────────────────────── */
.contact__h2 {
  font-family: 'Inter Tight', sans-serif;
  font-size: 72px;
  font-weight: 500;
  line-height: 0.95;
  letter-spacing: -2.4px;
  margin-bottom: 32px;
}

.contact__p1 {
  font-size: 17px;
  line-height: 1.55;
  color: var(--fg-dim);
  max-width: 420px;
  margin-bottom: 20px;
}

.contact__p2 {
  font-size: 15px;
  line-height: 1.6;
  color: var(--fg-mute);
  max-width: 420px;
  margin-bottom: 40px;
}

.contact__meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  max-width: 420px;
  padding-top: 24px;
  border-top: 1px solid var(--line);
}

.contact__meta-key {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--fg-mute);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.contact__meta-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  color: var(--fg);
}

/* ─── Form card ─────────────────────────────────────────────────── */
.contact-form-card {
  border: 1px solid var(--line-strong);
  padding: 32px;
  background: var(--bg-2);
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.contact-form__row-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.contact-form__field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.contact-form__label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--fg-mute);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.contact-form__input,
.contact-form__textarea {
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--line-strong);
  padding-bottom: 10px;
  font-family: 'Inter Tight', sans-serif;
  font-size: 14px;
  color: var(--fg);
  outline: none;
  resize: none;
  transition: border-color 100ms ease-out;
}

.contact-form__input::placeholder,
.contact-form__textarea::placeholder {
  color: var(--fg-mute);
}

.contact-form__input:focus,
.contact-form__textarea:focus {
  border-bottom-color: var(--accent);
}

.contact-form__textarea {
  min-height: 96px;
  line-height: 1.55;
}

.contact-form__error {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 0.3px;
  min-height: 16px;
}

.contact-form__submit {
  width: 100%;
  padding: 16px;
  background: var(--accent);
  color: #0A0A0A;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  border: none;
  border-radius: 2px;
  margin-top: 12px;
  transition: opacity 100ms ease-out;
}
.contact-form__submit:hover:not(:disabled) { opacity: 0.88; }
.contact-form__submit:disabled { opacity: 0.5; cursor: not-allowed; }

.contact-form__status {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.3px;
  min-height: 20px;
  text-align: center;
}
.contact-form__status--ok  { color: var(--accent); }
.contact-form__status--err { color: #F06A4C; }

/* ─── Responsive ──────────────────────────────────────────────────── */
@media (max-width: 1199px) {
  .contact__grid { grid-template-columns: 120px 1fr 1fr; gap: 40px; }
  .contact__h2 { font-size: 56px; letter-spacing: -1.8px; }
}

@media (max-width: 999px) {
  .contact__grid { grid-template-columns: 1fr; gap: 40px; }
}

@media (max-width: 767px) {
  .contact__h2 { font-size: 44px; letter-spacing: -1.4px; }
  .contact-form__row-2 { grid-template-columns: 1fr; }
}
</style>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement;
const submit = document.getElementById('cf-submit') as HTMLButtonElement;
const status = document.getElementById('cf-status') as HTMLParagraphElement;

function setError(id: string, msg: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = msg;
}
function clearErrors() {
  ['cf-name-error', 'cf-email-error', 'cf-message-error'].forEach((id) => setError(id, ''));
  status.textContent = '';
  status.className = 'contact-form__status';
}

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  clearErrors();

  const data = {
    name:    (form.elements.namedItem('name')    as HTMLInputElement).value.trim(),
    company: (form.elements.namedItem('company') as HTMLInputElement).value.trim(),
    email:   (form.elements.namedItem('email')   as HTMLInputElement).value.trim(),
    message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
  };

  // Client-side validation
  let hasError = false;
  if (!data.name) {
    setError('cf-name-error', 'NAME IS REQUIRED');
    hasError = true;
  }
  if (!data.email) {
    setError('cf-email-error', 'EMAIL IS REQUIRED');
    hasError = true;
  } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
    setError('cf-email-error', 'INVALID EMAIL ADDRESS');
    hasError = true;
  }
  if (!data.message) {
    setError('cf-message-error', 'PLEASE DESCRIBE WHAT YOU NEED');
    hasError = true;
  }
  if (hasError) return;

  submit.disabled = true;
  submit.textContent = 'Sending…';

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const json = await res.json();

    if (res.ok) {
      status.textContent = '✓ SENT — WE\'LL REPLY WITHIN ONE BUSINESS DAY';
      status.className = 'contact-form__status contact-form__status--ok';
      form.reset();
    } else {
      status.textContent = (json.error || 'SOMETHING WENT WRONG. PLEASE TRY AGAIN.').toUpperCase();
      status.className = 'contact-form__status contact-form__status--err';
    }
  } catch {
    status.textContent = 'NETWORK ERROR — PLEASE TRY AGAIN.';
    status.className = 'contact-form__status contact-form__status--err';
  } finally {
    submit.disabled = false;
    submit.textContent = 'Send — reply in 1 business day →';
  }
});
</script>
